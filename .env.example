# ==========================================================================
# TeamTask Configuration Environment Settings
# ==========================================================================

# Port the backend API will run on (Default: 5000)
PORT=5000

# JSON Web Token Encryption Key
JWT_SECRET=teamtask-super-secret-key-13579

# Production Database URL (Railway auto-injects this when deploying PostgreSQL)
# If left blank, the app will automatically fall back to a local SQLite database file.
# DATABASE_URL=postgres://user:password@host:port/database

# Node Environment
NODE_ENV=development
